{
	"name": "vcljs",
	"module": "index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"start": "bun run index.ts",
		"test": "bun run test/run-tests.ts",
		"test:basic": "bun run test/basic-vcl-tests.ts",
		"test:stdlib": "bun run test/stdlib-tests.ts",
		"test:caching": "bun run test/caching-tests.ts",
		"test:backend": "bun run test/backend-error-tests.ts",
		"test:root": "bun run test/run-root-tests.ts",
		"test:integration": "bun run test/run-integration-tests.ts",
		"test:tables": "bun test ./test/table-functions-tests.ts ./test/direct-table-functions-tests.ts ./test/vcl-table-functions-tests.ts",
		"test:browser": "bun run test/browser-bundle-smoke.test.ts",
		"test:compat": "bun test ./test/crypto-compat.test.ts",
		"test:all": "bun run test && bun run test:root && bun run test:integration && bun run test:tables && bun run test:compat && bun run test:browser",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/bun": "^1.3.10",
		"@types/chai": "^5.2.3",
		"chai": "^6.2.2"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@noble/ciphers": "^2.2.0",
		"@noble/hashes": "^2.2.0",
		"@types/uuid": "^11.0.0",
		"js-xxhash": "^5.0.1",
		"uuid": "^13.0.0"
	}
}
